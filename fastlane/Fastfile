# Onyx Terminal Fastlane Configuration
# This file contains the fastlane.tools configuration

default_platform(:ios)

platform :ios do
  desc "Run SwiftLint"
  lane :lint do
    # Install SwiftLint if not available
    sh("which swiftlint || brew install swiftlint") rescue nil
    
    # Run SwiftLint
    swiftlint(
      mode: :lint,
      config_file: ".swiftlint.yml",
      raise_if_swiftlint_error: true,
      ignore_exit_status: false
    )
  end

  desc "Run tests"
  lane :test do
    # Generate Xcode project if needed
    if !File.exist?("OnyxTerminal.xcodeproj")
      sh("xcodegen generate")
    end

    # Run tests
    scan(
      workspace: "OnyxTerminal.xcworkspace",
      scheme: "OnyxTerminal",
      device: "iPhone 15 Pro",
      clean: true,
      code_coverage: true,
      derived_data_path: "DerivedData",
      result_bundle: true,
      output_directory: "fastlane/test_output",
      output_types: "html,junit",
      fail_build: true
    )
  end

  desc "Build debug version"
  lane :build_debug do
    # Generate Xcode project if needed
    if !File.exist?("OnyxTerminal.xcodeproj")
      sh("xcodegen generate")
    end

    # Build for debug
    gym(
      workspace: "OnyxTerminal.xcworkspace",
      scheme: "OnyxTerminal",
      configuration: "Debug",
      derived_data_path: "DerivedData",
      output_directory: "fastlane/build_output",
      output_name: "OnyxTerminal-Debug.ipa",
      export_method: "development",
      skip_package_ipa: true,
      skip_archive: false,
      clean: true,
      build_path: "build"
    )
  end

  desc "Build release version"
  lane :build_release do
    # Generate Xcode project if needed
    if !File.exist?("OnyxTerminal.xcodeproj")
      sh("xcodegen generate")
    end

    # TODO: Configure signing with match or manual certificates
    # For now, this is a placeholder that will need proper code signing setup
    
    UI.important("⚠️  Release build requires code signing configuration")
    UI.important("📝 TODO: Set up fastlane match or configure manual signing")
    
    # Uncomment and configure when signing is set up:
    # gym(
    #   workspace: "OnyxTerminal.xcworkspace",
    #   scheme: "OnyxTerminal",
    #   configuration: "Release",
    #   derived_data_path: "DerivedData",
    #   output_directory: "fastlane/build_output",
    #   output_name: "OnyxTerminal-Release.ipa",
    #   export_method: "app-store",
    #   clean: true
    # )
  end

  desc "Run all checks (lint + test + build_debug)"
  lane :ci do
    lint
    test
    build_debug
  end

  desc "Deploy to TestFlight"
  lane :beta do
    # Generate Xcode project if needed
    if !File.exist?("OnyxTerminal.xcodeproj")
      sh("xcodegen generate")
    end

    # Create App Store Connect API Key from environment variables
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: Base64.decode64(ENV["ASC_PRIVATE_KEY"]),
      duration: 1200, # optional (maximum 1200)
      in_house: false
    )

    # Increment build number based on latest TestFlight build
    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.onx999.OnyxTerminal"
      ) + 1
    )

    # Build the app for release
    gym(
      workspace: "OnyxTerminal.xcworkspace",
      scheme: "OnyxTerminal",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "fastlane/build_output",
      output_name: "OnyxTerminal-Release.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.onx999.OnyxTerminal" => "match AppStore com.onx999.OnyxTerminal"
        }
      }
    )

    # Upload to TestFlight
    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false, # Internal testing only by default
      notify_external_testers: false,
      ipa: "fastlane/build_output/OnyxTerminal-Release.ipa"
    )
  end
end
